# NextKAN environment configuration
#
# Copy this file to `.env` (or `.env.local`) and fill in values.
# Every variable listed is optional unless marked REQUIRED.

# --- Core ---------------------------------------------------------------

# REQUIRED. Prisma datasource (SQLite file path or Postgres connection string).
DATABASE_URL="file:./dev.db"

# REQUIRED for production. NextAuth.js v5 session-encryption secret.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public site identity (also configurable via the admin Settings UI).
SITE_NAME="NextKAN"
SITE_URL="http://localhost:3000"

# --- Storage ------------------------------------------------------------

# Legacy upload directory used by the existing SQLite-backed import pipeline.
# Files referenced by `Distribution.filePath` live under this path.
UPLOAD_DIR="public/uploads"

# Storage provider for new uploads: "local" (default) or "s3".
STORAGE_PROVIDER="local"

# Root path for the agent-first storage tree (Parquet + original-of-record).
# New Distribution uploads write to `<NEXTKAN_STORAGE_PATH>/resources/<id>/`.
# All Parquet/original paths stored in the database are relative to this root.
NEXTKAN_STORAGE_PATH="./storage"

# Maximum upload size for the agent-first profiling pipeline, in MB.
NEXTKAN_UPLOAD_MAX_SIZE_MB=100

# Maximum size for remote-fetched downloads, in bytes.
REMOTE_DOWNLOAD_MAX_SIZE=

# S3-compatible object storage (used only when STORAGE_PROVIDER=s3).
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- MCP server ---------------------------------------------------------

# Port the sibling MCP server listens on.
NEXTKAN_MCP_PORT=3001

# DuckDB memory limit for both profiling workers and the MCP server.
NEXTKAN_DUCKDB_MEMORY_LIMIT="2GB"

# pino log level for the MCP server. Accepts: trace | debug | info | warn | error | fatal.
LOG_LEVEL="info"

# Public MCP endpoint URL surfaced to the admin agent-preview panel. Must be
# reachable from the browser, so use a hostname clients can resolve (not "mcp").
NEXT_PUBLIC_NEXTKAN_MCP_URL="http://localhost:3001/mcp"

# --- AI features (optional) --------------------------------------------

# Anthropic API key. When absent, all AI features disable gracefully —
# the catalog still works end-to-end without it.
ANTHROPIC_API_KEY=

# Anthropic model used by the AI adapter (`src/lib/ai/`).
NEXTKAN_AI_MODEL="claude-sonnet-4-6"

# --- Email (optional) ---------------------------------------------------

EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Feature flags ------------------------------------------------------

ENABLE_COMMENTS="true"
ENABLE_WORKFLOW="false"
ENABLE_PLUGINS="false"
COMMENT_MODERATION="auto"

# --- Users --------------------------------------------------------------

USER_REGISTRATION_MODE="open"   # "open" | "invite" | "closed"
USER_DEFAULT_ROLE="viewer"

# Seed admin credentials. Used by `npx prisma db seed` to create the initial
# admin account. Change before exposing the catalog publicly.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# --- Harvest ------------------------------------------------------------

# Bearer token required to trigger harvest jobs via API.
HARVEST_API_KEY=
